# IMAP mailbox connection — copy this file to .env and fill in real values.
# .env is gitignored; never commit your real password.

# IMAP server hostname. Examples:
#   NetEase 163:   imap.163.com
#   NetEase 126:   imap.126.com
#   Gmail:         imap.gmail.com
#   Outlook:       outlook.office365.com
#   QQ:            imap.qq.com
#   Fastmail:      imap.fastmail.com
IMAP_HOST=imap.163.com

# IMAP over SSL port (almost always 993).
IMAP_PORT=993

# Full login (usually the full email address).
IMAP_LOGIN=you@example.com

# App-specific password / authorization code, NOT your login password.
# Most providers require IMAP/SMTP to be enabled and a separate app password
# to be generated in the account settings:
#   - 163/126:    https://mail.163.com → 设置 → POP3/SMTP/IMAP → 开启 IMAP/SMTP → 授权码
#   - Gmail:     https://myaccount.google.com/apppasswords (must have 2FA on)
#   - QQ:        https://service.mail.qq.com → 设置 → 账户 → IMAP/SMTP 服务 → 开启 → 授权码
#   - Outlook:   app password from Microsoft 365 account security
IMAP_PASSWORD=your-app-specific-password

# Mailbox to read. Default INBOX; some providers use "All Mail" for Gmail.
MAILBOX=INBOX

# Your local timezone for naive date math in the test-reminder skill
# (e.g. when a mail says "7月10日 19:00" without a timezone, we use this).
# Defaults to UTC if unset. Examples: Asia/Shanghai, America/New_York, Europe/London.
TZ=Asia/Shanghai